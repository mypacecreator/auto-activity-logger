# =============================================================================
# auto-activity-logger - 環境変数設定ファイル
# =============================================================================
# このファイルを .env にコピーして値を記入してください:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Chatwork API
# -----------------------------------------------------------------------------
# APIトークン取得: https://www.chatwork.com/service/packages/chatwork/subpackages/api/token.php
CHATWORK_API_TOKEN=your_chatwork_api_token_here

# 自分のアカウントID（「自分の発言のみ」にフィルタするために使用）
# 以下で確認できます: curl -H "X-ChatWorkToken: <YOUR_TOKEN>" https://api.chatwork.com/v2/me
CHATWORK_MY_ACCOUNT_ID=your_account_id_here

# 取得対象ルームID（カンマ区切り。例: 12345,67890）
# 空にすると参加している全ルームを走査します（API呼び出しが増えます）
CHATWORK_ROOM_IDS=

# -----------------------------------------------------------------------------
# GitHub API
# -----------------------------------------------------------------------------
# Personal Access Token 取得: https://github.com/settings/tokens
# 必要スコープ: read:user、プライベートリポジトリのイベントも取得する場合は repo
GITHUB_TOKEN=your_github_personal_access_token_here

# GitHubユーザー名（/users/{username}/events の取得に使用）
GITHUB_USERNAME=your_github_username_here

# -----------------------------------------------------------------------------
# 出力設定（任意）
# -----------------------------------------------------------------------------
# ログ取得対象の日付デフォルト値: "today"（当日）または "yesterday"（前日）
# CLIオプションで上書き可能: npm start -- --date today
DEFAULT_DATE=yesterday

# 出力先ディレクトリ（プロジェクトルートからの相対パス）
OUTPUT_DIR=logs

# 日付境界計算に使用するタイムゾーン（IANAタイムゾーン名）
# 例: "Asia/Tokyo"、"America/New_York"、"UTC"
# 空にするとシステムのデフォルトタイムゾーンを使用します。
# TIMEZONE=Asia/Tokyo

# -----------------------------------------------------------------------------
# スクリーンショット設定（任意）
# -----------------------------------------------------------------------------
# CleanShot X のスクリーンショット保存先ディレクトリ。
# ~ はホームディレクトリとして展開されます。空にするとスキャンを無効化します。
# CleanShot X のデフォルト保存先: ~/Downloads/CleanShot
SCREENSHOT_DIR=~/Downloads/CleanShot

# -----------------------------------------------------------------------------
# Gmail API（Google Workspace + サービスアカウント）
# -----------------------------------------------------------------------------
# サービスアカウント JSON キーファイルのパス（プロジェクトルートからの相対パス）。
# 詳細なセットアップ手順は README を参照してください。
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./credentials/service-account.json

# 取得対象の Gmail アドレス（Workspace ドメインに属している必要があります）。
GMAIL_ADDRESS=you@yourcompany.com

# 受信メールの監視対象ラベル（Gmailラベル名をカンマ区切りで指定）。
# 対象メッセージにのみラベルが付くよう、事前にGmailのフィルタ設定を行ってください。
# 例: GMAIL_WATCHED_LABELS=GS_log
GMAIL_WATCHED_LABELS=
