# =============================================================================
# auto-activity-logger - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Chatwork API
# -----------------------------------------------------------------------------
# API Token: https://www.chatwork.com/service/packages/chatwork/subpackages/api/token.php
CHATWORK_API_TOKEN=your_chatwork_api_token_here

# Your own account ID (used to filter "only my messages")
# Check via: curl -H "X-ChatWorkToken: <YOUR_TOKEN>" https://api.chatwork.com/v2/me
CHATWORK_MY_ACCOUNT_ID=your_account_id_here

# Room IDs to scan (comma-separated, e.g. 12345,67890)
# Leave empty to scan ALL rooms you are a member of (slower, more API calls)
CHATWORK_ROOM_IDS=

# -----------------------------------------------------------------------------
# GitHub API
# -----------------------------------------------------------------------------
# Personal Access Token: https://github.com/settings/tokens
# Required scopes: read:user, repo (for private repo events)
GITHUB_TOKEN=your_github_personal_access_token_here

# Your GitHub username (used to fetch /users/{username}/events)
GITHUB_USERNAME=your_github_username_here

# -----------------------------------------------------------------------------
# Output Settings (optional)
# -----------------------------------------------------------------------------
# Default date to collect logs for: "today" or "yesterday"
# Can be overridden by CLI option: npm start -- --date today
DEFAULT_DATE=yesterday

# Output directory (relative to project root)
OUTPUT_DIR=logs
